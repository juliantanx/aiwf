{
  "name": "aiwf",
  "version": "0.1.0",
  "description": "AI Workflow CLI - Manage AI workflows for team collaboration",
  "keywords": [
    "ai",
    "workflow",
    "cli",
    "llm",
    "agent",
    "automation"
  ],
  "author": "juliantanx",
  "license": "MIT",
  "type": "module",
  "bin": {
    "aiwf": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "schemas",
    "templates"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js",
    "test:coverage": "npm test -- --coverage",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "ajv": "^8.17.1",
    "chalk": "^5.4.1",
    "commander": "^13.1.0",
    "cosmiconfig": "^9.0.0",
    "dotenv": "^16.5.0",
    "inquirer": "^12.6.0",
    "js-yaml": "^4.1.0",
    "ollama": "^0.5.15",
    "openai": "^4.97.0",
    "ora": "^8.2.0",
    "simple-git": "^3.27.0",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.0",
    "@types/jest": "^29.5.14",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.14.1",
    "@types/uuid": "^10.0.0",
    "eslint": "^9.25.1",
    "jest": "^29.7.0",
    "ts-jest": "^29.3.2",
    "tsup": "^8.4.0",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.59.1"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/juliantanx/aiwf.git"
  },
  "bugs": {
    "url": "https://github.com/juliantanx/aiwf/issues"
  },
  "homepage": "https://github.com/juliantanx/aiwf#readme"
}
